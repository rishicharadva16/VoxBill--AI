# Copy this file to backend/.env and fill in your values
# NEVER commit backend/.env to version control

# MongoDB Atlas connection string
# Get from: Atlas Dashboard → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret — must be a long random string
# Generate one by running: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_random_secret_here_minimum_32_characters

# Backend server port
PORT=4000
