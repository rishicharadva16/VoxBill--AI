{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "AI_URL": "https://voxbill-ai.onrender.com/process-order",
    "BACKEND_URL": "https://voxbill-backend.onrender.com"
  }
}